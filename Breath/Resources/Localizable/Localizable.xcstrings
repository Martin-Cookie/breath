    "settings.safety_disclaimer" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nikdy necvič ve vodě ani při řízení. Při závratích okamžitě přestaň a normálně dýchej. Pokud máš zdravotní potíže, poraď se s lékařem."
          }
