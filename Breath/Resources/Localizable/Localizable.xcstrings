    "onboarding.notifications.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pošleme ti každé ráno připomínku, ať na cvičení nezapomeneš. Čas můžeš kdykoliv změnit v nastavení."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We'll remind you each morning so you don't skip a day. You can change the time anytime in settings."
          }
        }
      }
    },
