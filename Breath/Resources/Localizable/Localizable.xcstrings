    "onboarding.welcome.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cvičení probíhá v kolech: 30–40 hlubokých nádechů, pak výdech a zadržení dechu. Na konci kola se zhluboka nadechneš a krátce podržíš."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each round: 30–40 deep breaths, then exhale and hold. At the end, inhale deeply and briefly hold."
          }
        }
      }
    },
    "onboarding.welcome.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
