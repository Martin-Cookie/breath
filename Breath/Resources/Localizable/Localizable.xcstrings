    "onboarding.safety.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nikdy necvič ve vodě ani při řízení. Při závratích okamžitě přestaň. Pokud máš zdravotní potíže, poraď se s lékařem."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Never practice in water or while driving. Stop if you feel dizzy. Consult a doctor if you have health conditions."
          }
        }
      }
    },
    "onboarding.safety.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cvič vždy vsedě nebo vleže"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Always practice sitting or lying down"
          }
        }
      }
    },
    "onboarding.safety.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
